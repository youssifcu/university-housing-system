  gender: 'male',
  dateOfBirth: '',
  phoneNumber: '',
  email: '',
  address: '',
  emergencyContactName: '',
  emergencyContactPhone: '',
  emergencyContactRelation: 'Father',
  college: '',
  department: '',
  academicYear: '',
  gpa: '',
  housingType: 'normal',
  hasSpecialNeeds: false,
  specialNeedsDescription: '',
  preferredRoommate: '',
};

