  title: University Housing System API
  version: "2.0.0"
  description: |
    Complete API documentation for University Housing System.
    - **Authentication:** Firebase Bearer token required for most endpoints.
    - **Roles:** student, admin, supervisor, floor_admin, meal_admin.
servers:
  - url: http://localhost:5000
    description: Local Development Server
  - url: https://university-housing-api.up.railway.app
    description: Railway Production Server
security:
  - bearerAuth: []
tags:
  - name: Auth
    description: Authentication & profile management
  - name: Applications
    description: Housing admission applications
  - name: Buildings
    description: Dormitory buildings
  - name: Rooms
    description: Rooms and assignment
  - name: Housing Requests
