          schema: { type: string }
      responses:
        '200':
          description: Success
        '404':
          $ref: '#/components/responses/NotFound'
  /api/applications/{id}/approve:
    patch:
      tags: [Applications]
      summary: Approve application (Admin)
      description: |
        Approve housing application and assign room based on:
        - Student's gender
        - Student's academic grade (derived from GPA)
        - Building grade requirements
        
        Student will be assigned to a building matching their grade level.
        Their grade (1-10) determines eligible buildings for future room transfers.
      security: [{ bearerAuth: [] }]
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: string }
      responses:
        '200':
          description: Approved and assigned to room with grade level considered
        '400':
          description: No buildings found matching student's grade level
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
