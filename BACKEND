components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
  schemas:
    ErrorResponse:
      type: object
      properties:
        success:
          type: boolean
          example: false
        message:
          type: string
        error:
          type: string
    SuccessResponse:
      type: object
      properties:
        success:
          type: boolean
          example: true
        message:
          type: string
        data:
          type: object
    User:
      type: object
      properties:
        _id:
          type: string
        name:
          type: string
        email:
          type: string
        role:
          type: string
        phoneNumber:
          type: string
        profilePicture:
          type: string
        housingStatus:
          type: string
    ApplicationInput:
      type: object
      required:
        - studentType
        - nationalId
        - fullName
        - gender
        - dateOfBirth
        - phoneNumber
        - address
        - fatherName
        - fatherNationalId
        - college
        - academicYear
      properties:
        studentType:
          type: string
          enum: [new, returning]
        nationalId:
          type: string
        fullName:
          type: string
        gender:
          type: string
          enum: [male, female]
        dateOfBirth:
          type: string
          format: date
        phoneNumber:
          type: string
        address:
          type: string
        fatherName:
          type: string
        fatherNationalId:
          type: string
        fatherPhone:
          type: string
        college:
          type: string
        academicYear:
          type: string
        gpa:
          type: number
        housingType:
          type: string
          enum: [normal, distinguished]
        specialNeeds:
          type: boolean
        documents:
          type: object
          properties:
            nationalIdCard:
              type: string
            personalPhoto:
              type: string
            medicalReport:
              type: string
    HousingRequestInput:
      type: object
      required:
        - type
        - reason
      properties:
        type:
          type: string
          enum: [transfer, leave, vacate, maintenance]
          description: Type of housing request (transfer requests validate student grade against target building)
        toRoomId:
          type: string
          description: Required for transfer requests. Target room must be in a building matching student's grade level.
        reason:
          type: string
        startDate:
          type: string
          format: date
        endDate:
          type: string
          format: date
    BuildingInput:
      type: object
      required:
        - name
        - gender
        - floors
        - grade
      properties:
        name:
          type: string
        gender:
          type: string
          enum: [male, female]
        floors:
          type: integer
        grade:
          type: integer
          minimum: 1
          maximum: 10
          description: Required grade level for housing eligibility (1-10)
        description:
          type: string
        supervisorId:
          type: string
    RoomInput:
      type: object
      required:
        - buildingId
        - floorNumber
        - roomNumber
        - capacity
      properties:
        buildingId:
          type: string
        floorNumber:
          type: integer
        roomNumber:
          type: string
        capacity:
          type: integer
        amenities:
          type: array
          items:
            type: string
    MealInput:
      type: object
      required:
        - name
        - mealType
        - date
      properties:
        name:
          type: string
        mealType:
          type: string
          enum: [breakfast, lunch, dinner, snack]
        price:
          type: number
        date:
          type: string
          format: date
        maxBookings:
          type: integer
        description:
          type: string
    AnnouncementInput:
      type: object
      required:
        - title
        - content
      properties:
        title:
          type: string
        content:
          type: string
        priority:
          type: string
          enum: [low, medium, high]
        targetRole:
          type: string
          enum: [all, student, supervisor, admin]
        expiresAt:
          type: string
          format: date-time
    NotificationInput:
      type: object
      required:
        - title
        - message
      properties:
        title:
          type: string
        message:
          type: string
        targetUser:
          type: string
        targetRole:
          type: string
        type:
          type: string
          enum: [info, warning, success, meal, attendance, announcement]
    ValidateQRRequest:
      type: object
      required: [qrCode]
      properties:
        qrCode:
          type: string
  responses:
    Unauthorized:
      description: Missing or invalid token
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    Forbidden:
      description: Insufficient permissions
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    NotFound:
      description: Resource not found
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'
    ServerError:
      description: Internal server error
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ErrorResponse'

paths:
