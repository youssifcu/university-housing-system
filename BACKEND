        content:
          application/json:
            schema:
              type: object
              required: [firebaseUid, email, name, phoneNumber]
              properties:
                firebaseUid:
                  type: string
                email:
                  type: string
                name:
                  type: string
                phoneNumber:
                  type: string
                studentId:
                  type: string
                nationalId:
                  type: string
                universityYear:
                  type: string
                faculty:
                  type: string
      responses:
        '201':
          description: Registration successful
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
        '400':
          $ref: '#/components/responses/ErrorResponse'
        '500':
          $ref: '#/components/responses/ServerError'
