              "type": "number",
              "default": 20
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["pending", "approved", "rejected", "needs_update"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Applications retrieved"
          }
        }
      }
  
    },
